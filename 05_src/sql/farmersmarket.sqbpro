ttings></tab_browse><tab_sql><sql name="SELECT.sql" filename="/Users/teresaorbillo/sql/sql/05_src/sql/SELECT.sql">-- Reference to file &quot;/Users/teresaorbillo/sql/sql/05_src/sql/SELECT.sql&quot; (not supported by this version) --</sql><sql name="SQL 3*">SELECT *
CASE WHEN vendor_type = 'fresh focused' THEN 'Wednesday'
	WHEN vendor_type = 'EGGS AND MEATS' THEN 'THURSDAY'
	ELSE 'SATURDAY'
	END AS day_of_specialty
	
	CASE WHEN vendor_name = &quot;annie's place&quot;
		THEN 'annie is the best'
		END as pi_day
		</sql><current_tab id="1"/></tab_sql></sqlb_project>
